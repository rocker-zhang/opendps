    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "current": {},
        "hide": 0
      },
      {
        "name": "domain",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(opendps_domain_power_draw_watts, domain)",
        "query": "label_values(opendps_domain_power_draw_watts, domain)",
        "label": "Domain",
        "current": {},
        "hide": 0,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
